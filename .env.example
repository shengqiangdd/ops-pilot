# ============================================
# OpsPilot Configuration
# ============================================

# ─── Database ───────────────────────────────
# SQLite (default) or PostgreSQL
DATABASE_URL=sqlite:///app/data/ops-pilot.db

# ─── Authentication ────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ─── LLM Provider ─────────────────────────
# Supported: ollama | openai | deepseek | mimo
LLM_PROVIDER=mimo

# API Key (required for cloud providers)
# MiMo: get from https://mimo.mi.com
# OpenAI: get from https://platform.openai.com
# DeepSeek: get from https://platform.deepseek.com
MIMO_API_KEY=sk-xxxxxxxxxxxxxxxx

# Base URL (auto-set based on provider, override if needed)
# MiMo pay-as-you-go:  https://api.xiaomimimo.com/v1
# MiMo token plan:      https://token-plan-cn.xiaomimimo.com/v1
# Ollama (local):       http://localhost:11434/v1
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Model name
LLM_MODEL=mimo-v2.5

# ─── Server ────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ─── OpenCode Go (for AI coding agent) ─────
# Subscribe at: https://opencode.ai/go
# Get API key from: https://opencode.ai/auth
OPENCODE_API_KEY=

# ─── SSH ───────────────────────────────────
# Default SSH key path (optional)
# SSH_KEY_PATH=~/.ssh/id_rsa

# ─── Security ──────────────────────────────
# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=60

# ─── Modules ───────────────────────────────
# Enable/disable modules (comma-separated)
# Enabled modules: rca,finops,security,topo,chatops
ENABLED_MODULES=rca
