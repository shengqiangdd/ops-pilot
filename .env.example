# ============================================
# OpsPilot Configuration
# ============================================

# ─── Server ────────────────────────────────
LISTEN_ADDR=0.0.0.0:3001
STATIC_DIR=./static

# ─── Database ───────────────────────────────
# SQLite (default)
DATABASE_URL=sqlite:ops-pilot.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgres://ops_pilot:ops_pilot@localhost:5432/ops_pilot

# ─── Authentication ────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ─── LLM Provider ─────────────────────────
# Supported: openai | deepseek | ollama | mimo
# Default uses remote API (openai). For local Ollama:
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://ollama:11434/v1 (or http://host.docker.internal:11434/v1)
#   then: docker compose --profile ollama up -d
LLM_PROVIDER=openai

# API Key (required for cloud providers)
# OpenAI: get from https://platform.openai.com
# DeepSeek: get from https://platform.deepseek.com
# MiMo: get from https://mimo.mi.com
LLM_API_KEY=sk-...

# Base URL (auto-set based on provider, override if needed)
# OpenAI:    https://api.openai.com/v1
# Ollama:    http://localhost:11434/v1
# DeepSeek:  https://api.deepseek.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name
LLM_MODEL=gpt-4o-mini

# ─── Vault ─────────────────────────────────
# Master key for host credential encryption
# Generate with: openssl rand -base64 32
VAULT_ENCRYPTION_KEY=change-me-too

# ─── SSH ───────────────────────────────────
# Default SSH key path (optional)
# SSH_KEY_PATH=~/.ssh/id_rsa

# ─── Security ──────────────────────────────
# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=60

# ─── Modules ───────────────────────────────
# Enable/disable modules (comma-separated)
# Available: mod-core, mod-rca, mod-security
ENABLED_MODULES=mod-core,mod-rca,mod-security
