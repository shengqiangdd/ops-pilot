{
  "$schema": "https://mimo.xiaomi.com/mimocode/config.json",
  "model": "opencode-go/mimo-v2.5-pro",
  "small_model": "opencode-go/mimo-v2.5",
  "provider": {
    "opencode-go": {
      "name": "OpenCode Go",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "mimo-v2.5": {
          "name": "MiMo V2.5 (Fast & Cheap)"
        },
        "mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro (Best Coding)"
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (Fastest)"
        },
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code"
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6"
        },
        "qwen3.7-max": {
          "name": "Qwen 3.7 Max"
        },
        "qwen3.7-plus": {
          "name": "Qwen 3.7 Plus"
        },
        "minimax-m3": {
          "name": "MiniMax M3"
        },
        "glm-5.2": {
          "name": "GLM 5.2"
        }
      }
    }
  },
  "server": {
    "port": 4096
  },
  "permission": {
    "bash": "ask",
    "write": "ask",
    "edit": "ask"
  }
}
