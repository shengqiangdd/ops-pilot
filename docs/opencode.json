{
  "$schema": "https://mimo.xiaomi.com/mimocode/config.json",
  "model": "opencode-go/mimo-v2.5",
  "small_model": "opencode-go/mimo-v2.5",
  "provider": {
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "baseURL": "{env:OPENCODE_BASE_URL}",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "MiMo V2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "mimo-v2.5": {
          "name": "MiMo V2.5",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "agents": {
    "system-architect": {
      "file": "docs/agents/system-architect.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "rust-developer": {
      "file": "docs/agents/rust-developer.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "frontend-developer": {
      "file": "docs/agents/frontend-developer.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "code-reviewer": {
      "file": "docs/agents/code-reviewer.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "devops-engineer": {
      "file": "docs/agents/devops-engineer.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "testing-engineer": {
      "file": "docs/agents/testing-engineer.md",
      "model": "opencode-go/mimo-v2.5"
    },
    "documentation": {
      "file": "docs/agents/documentation.md",
      "model": "opencode-go/mimo-v2.5"
    }
  },
  "mcp": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/app/working/workspaces/default/ops-pilot"
      ],
      "enabled": true
    },
    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-docker"
      ],
      "enabled": true
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    }
  },
  "keybindings": "vim",
  "theme": "dark"
}