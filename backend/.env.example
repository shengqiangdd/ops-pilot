# OpsPilot 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# === 必填 ===
JWT_SECRET=                                     # openssl rand -hex 32
OPSPILOT_MASTER_KEY=                            # openssl rand -base64 32

# === LLM 配置 ===
LLM_PROVIDER=ollama                             # openai | ollama | deepseek
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=                                    # OpenAI/DeepSeek 需要
LLM_MODEL=qwen2.5:32b

# === 数据库 ===
DATABASE_URL=sqlite:///app/data/ops-pilot.db

# === 日志 ===
RUST_LOG=ops_pilot=info,tower_http=info

# === 服务 ===
LISTEN_ADDR=0.0.0.0:3001
STATIC_DIR=./frontend/dist

# === 时区 ===
TZ=Asia/Shanghai
